# ------------------------------------------------------------
# supabase (from supabase project settings -> api)
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ------------------------------------------------------------
# app urls
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# api runtime
# ------------------------------------------------------------
PORT=3001
NODE_ENV=development

# comma-separated list of origins allowed to call api/ws.
# required when NODE_ENV is not development.
ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# database (optional for direct psql/migrations)
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ------------------------------------------------------------
# optional (reserved for socket scaling in future versions)
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379
