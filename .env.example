# ─────────────────────────────────────────
# Supabase (get from https://app.supabase.com → Settings → API)
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://nwlxznkhjrxpnfhggxke.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT secret (from Supabase: Settings → API → JWT Settings → JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ─────────────────────────────────────────
# Database (for direct connections / migrations)
# ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.nwlxznkhjrxpnfhggxke.supabase.co:5432/postgres

# ─────────────────────────────────────────
# NestJS API
# ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────
# Frontend → Backend URL
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─────────────────────────────────────────
# Redis (optional for v1 — used for Socket.IO scaling in v2)
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
